# Knowly environment. Copy to `.env` (gitignored):  cp env.example .env
# The backend refuses to start if a required variable is missing (check-env.sh).

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=knowly
POSTGRES_PASSWORD=knowly
POSTGRES_DB=knowly
# Async SQLAlchemy URL (asyncpg). Host `db` is the compose service name.
DATABASE_URL=postgresql+asyncpg://knowly:knowly@db:5432/knowly

# ── Application ───────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
SESSION_LIFETIME_DAYS=14
FRONTEND_ORIGIN=https://localhost
EDIT_NOTIFICATION_GRACE_SECONDS=300
FRIEND_REREQUEST_COOLDOWN_HOURS=0

# ── OAuth (Google) — optional until the OAuth task ────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://localhost/api/auth/google/callback

# ── LLM + moderation — optional until those tasks ─────────────
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_RATE_LIMIT_PER_HOUR=30
MODERATION_ENABLED=true
MODERATION_THRESHOLD=0.5
MODERATION_THRESHOLD_OVERRIDES=

# ── Admin bootstrap ───────────────────────────────────────────
INITIAL_ADMIN_EMAIL=

# ── Storage ───────────────────────────────────────────────────
UPLOAD_MAX_BYTES=5242880
AVATAR_MAX_BYTES=2097152
